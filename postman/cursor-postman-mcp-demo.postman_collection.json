{
  "info": {
    "name": "cursor-postman-mcp-demo REST API",
    "description": "Coleccion generada desde controladores Spring Boot.\nAPI sin autenticacion para estos endpoints.\nbaseUrl se define en variables de coleccion para evitar dependencia de globals.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "description": "Base URL local de Spring Boot"
    }
  ],
  "item": [
    {
      "name": "Users",
      "description": "Controlador origen: UserController (/api/v1/users).\nPath params reales: id (en /{id} y /{id}/orders).\nQuery params reales: No hay query params en este recurso.",
      "item": [
        { "name": "List Users", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/users", "description": "Origen: UserController.list. Query params: no hay." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () {","  pm.response.to.have.status(200);","});","pm.test('Respuesta JSON array', function () {","  pm.expect(Array.isArray(pm.response.json())).to.be.true;","});"] } }] },
        { "name": "Get User By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/users/:id", "description": "Origen: UserController.get. Path param: id. Query params: no hay." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () {","  pm.response.to.have.status(200);","});","pm.test('Respuesta JSON objeto', function () {","  pm.expect(pm.response.json()).to.be.an('object');","});"] } }] },
        { "name": "List User Orders", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/users/:id/orders", "description": "Origen: UserController.listOrders. Path param: id. Query params: no hay." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () {","  pm.response.to.have.status(200);","});","pm.test('Respuesta JSON array', function () {","  pm.expect(Array.isArray(pm.response.json())).to.be.true;","});"] } }] },
        { "name": "Create User", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ana Perez\",\n  \"email\": \"ana.perez@example.com\"\n}" }, "url": "{{baseUrl}}/api/v1/users", "description": "Origen: UserController.create. Query params: no hay." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 201', function () {","  pm.response.to.have.status(201);","});","pm.test('Respuesta JSON objeto', function () {","  pm.expect(pm.response.json()).to.be.an('object');","});"] } }] },
        { "name": "Update User", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ana Perez Actualizada\",\n  \"email\": \"ana.actualizada@example.com\"\n}" }, "url": "{{baseUrl}}/api/v1/users/:id", "description": "Origen: UserController.replace. Path param: id. Query params: no hay." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () {","  pm.response.to.have.status(200);","});","pm.test('Respuesta JSON objeto', function () {","  pm.expect(pm.response.json()).to.be.an('object');","});"] } }] },
        { "name": "Delete User", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/users/:id", "description": "Origen: UserController.delete. Path param: id. Query params: no hay." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 204', function () {","  pm.response.to.have.status(204);","});"] } }] }
      ]
